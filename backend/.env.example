# FinSight Configuration
FINSIGHT_HOST=0.0.0.0
FINSIGHT_PORT=8000
FINSIGHT_DEBUG=true
FINSIGHT_SECRET_KEY=change-this-to-a-random-secret-key

# Database (default: SQLite)
FINSIGHT_DB_URL=sqlite+aiosqlite:///./finsight.db

# CORS (comma-separated origins)
FINSIGHT_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Redis for caching
FINSIGHT_REDIS_URL=

# Optional: API Keys for enhanced data
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
NEWS_API_KEY=

# FRED (Federal Reserve Economic Data) - Get free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
